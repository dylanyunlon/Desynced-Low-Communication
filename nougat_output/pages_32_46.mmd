\[\frac{1}{TM}\sum_{t=0}^{T-1}\sum_{m=1}^{M}\mathbb{E}[\|x_{t}^{m}-x _{t}\|^{2}]=\mathcal{O}(\eta^{2}),\qquad\text{(extension of Lemma \ref{lem:L1})}\] \[\sum_{t=0}^{T-1}\mathbb{E}[\|\Gamma_{t-1}^{m}-\Gamma_{t}^{m}\|]= \mathcal{O}(1),\qquad\text{(follows from AMSGrad normalization)}\] \[\frac{1}{M}\sum_{t=0}^{T-1}\sum_{m=1}^{M}\mathbb{E}[\|g_{t}- \widetilde{g}_{t}^{m}\|]=\mathcal{O}(1),\qquad\text{(see below).}\]

